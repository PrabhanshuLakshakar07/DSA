package AssignmentsDSA;

import java.util.*;

class TwoStacks {
    int[] arr;
    int top1, top2;
    int size;

    public TwoStacks(int n) {
        size = n;
        arr = new int[n];
        top1 = -1;
        top2 = size;
    }

    void push1(int x) {
        if (top1 + 1 == top2) {
            System.out.println("Overflow");
            return;
        }
        arr[++top1] = x;
    }

    void push2(int x) {
        if (top1 + 1 == top2) {
            System.out.println("Overflow");
            return;
        }
        arr[--top2] = x;
    }

    int pop1() {
        if (top1 == -1) {
            return -1;
        }
        return arr[top1--];
    }

    int pop2() {
        if (top2 == size) {
            return -1;
        }
        return arr[top2++];
    }
}

public class main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter array size: ");
        int n = sc.nextInt();

        System.out.print("Enter number of queries: ");
        int q = sc.nextInt();

        TwoStacks ts = new TwoStacks(n);
        List<Integer> result = new ArrayList<>();

        System.out.println("Enter queries (push1 x | push2 x | pop1 | pop2):");

        for (int i = 0; i < q; i++) {
            String obj = sc.next();

            if (obj.equals("push1")) {
                int x = sc.nextInt();
                ts.push1(x);
            } else if (obj.equals("push2")) {
                int x = sc.nextInt();
                ts.push2(x);
            } else if (obj.equals("pop1")) {
                result.add(ts.pop1());
            } else if (obj.equals("pop2")) {
                result.add(ts.pop2());
            } else {
                System.out.println("Invalid input");
                i--;
            }
        }

        System.out.println("Output:");
        System.out.println(result);

        sc.close();
    }
}
