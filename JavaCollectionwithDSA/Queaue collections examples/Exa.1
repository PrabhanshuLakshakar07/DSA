import java.util.LinkedList;
import java.util.Queue;

public class Main {
    public static void main(String[] args) {
        // 1. Queue banaya (LinkedList ki madad se)
        Queue<Integer> q = new LinkedList<>();

        // 2. Add karna (Enqueue) - add() ya offer()
        q.add(10);
        q.add(20);
        q.add(30); 
        // Line aisi hai: [10, 20, 30] <-- 10 sabse aage hai

        // 3. Sabse aage wala dekhna (Peek)
        System.out.println("Front: " + q.peek()); // Output: 10

        // 4. Nikalna (Dequeue) - remove() ya poll()
        System.out.println("Removed: " + q.poll()); // 10 nikal gaya

        // 5. Baaki bachi queue
        System.out.println("Queue: " + q); // [20, 30]
    }
}
